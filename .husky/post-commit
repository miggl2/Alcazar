#!/usr/bin/env sh

# commit 직후 STATE.md에 한국어 한 줄 자동 추가 (압축 후 복원 시 사용)
if [ "$ALCAZAR_STATE_AMEND" = "1" ]; then
  exit 0
fi

COMMIT_MSG=$(git log -1 --pretty=%s)
COMMIT_DATE=$(git log -1 --pretty=%cd --date=format:'%Y-%m-%d %H:%M')

if [ -f STATE.md ]; then
  echo "- [$COMMIT_DATE] $COMMIT_MSG" >> STATE.md
  git add STATE.md
  if ! ALCAZAR_STATE_AMEND=1 git commit --amend --no-edit --no-verify >/dev/null 2>&1; then
    echo "STATE.md 자동 기록은 만들었지만 커밋에 포함하지 못했습니다. 다음 커밋에 함께 포함하세요."
  fi

  LINE_COUNT=$(wc -l < STATE.md)
  if [ "$LINE_COUNT" -gt 100 ]; then
    echo "STATE.md가 100줄을 넘었습니다. AI에게 'STATE.md 오래된 항목 한 줄로 요약해줘'라고 말해 정리하세요."
  fi
fi
