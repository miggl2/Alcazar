#!/usr/bin/env sh

STAGED_ENV=$(git diff --cached --name-only | grep -E '^\.env(\..*)?$' | grep -vE '\.example$' || true)
if [ -n "$STAGED_ENV" ]; then
  echo ""
  echo "❌ .env 파일이 commit에 포함되어 있어요. 절대 git에 올리지 마세요."
  echo "$STAGED_ENV"
  echo "   해결: git reset HEAD <파일명>"
  exit 1
fi

HAS_HEAD=0
if git rev-parse --verify HEAD >/dev/null 2>&1; then
  HAS_HEAD=1
fi

STAGED=$(git diff --cached --name-only | grep -vE '^(STATE\.md|\.intent/)' | wc -l | tr -d ' ')
if [ "$STAGED" -gt 5 ] && [ "$HAS_HEAD" -eq 1 ]; then
  echo ""
  echo "⚠️  $STAGED개 파일이 한 번에 변경됩니다 (5개 초과)."
  echo "   AI가 너무 많이 건드린 것일 수 있어요."
  if [ -t 0 ]; then
    echo "   계속하려면 y, 취소는 그냥 Enter: "
    exec < /dev/tty
    read -r answer
    if [ "$answer" != "y" ] && [ "$answer" != "Y" ]; then
      echo "취소됨. 작업을 5개 이하로 나누세요."
      exit 1
    fi
  else
    echo "   비대화 환경에서는 자동 취소합니다. 작업을 5개 이하로 나누세요."
    exit 1
  fi
elif [ "$STAGED" -gt 5 ]; then
  echo ""
  echo "ℹ️  첫 커밋 전 초기 세팅으로 보여 5파일 초과 확인을 건너뜁니다."
fi

node scripts/check.mjs
