{
  "name": "alcazar",
  "version": "0.1.0",
  "private": true,
  "description": "A mobile-first Alcazar puzzle game.",
  "packageManager": "npm@11.6.2",
  "scripts": {
    "intent": "node scripts/intent.mjs",
    "resume": "node scripts/resume.mjs",
    "check": "node scripts/check.mjs",
    "rollback": "node scripts/rollback.mjs",
    "summary": "node scripts/summary.mjs",
    "smoke": "node scripts/generator-smoke.mjs",
    "release:smoke": "node scripts/release-tooling-smoke.mjs",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "pages:check": "node scripts/github-pages-check.mjs",
    "pages:publish": "node scripts/github-pages-publish.mjs",
    "play:ready": "node scripts/play-store-readiness.mjs",
    "release:info": "node scripts/set-release-info.mjs",
    "assetlinks:write": "node scripts/write-assetlinks.mjs",
    "deploy-check": "node scripts/deploy-check.mjs",
    "snapshot": "node scripts/snapshot.mjs",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "prepare": "node scripts/prepare-husky.mjs",
    "manual": "node scripts/manual-router.mjs"
  },
  "dependencies": {
    "@fontsource/pretendard": "~5.1.0",
    "lucide-react": "~1.16.0",
    "next": "~14.2.35",
    "react": "~18.3.1",
    "react-dom": "~18.3.1",
    "zod": "~3.23.0"
  },
  "devDependencies": {
    "@types/node": "~22.0.0",
    "@types/react": "~18.3.0",
    "@types/react-dom": "~18.3.0",
    "autoprefixer": "~10.4.0",
    "eslint": "~8.57.0",
    "eslint-config-next": "~14.2.35",
    "husky": "~9.1.0",
    "postcss": "~8.4.0",
    "tailwindcss": "~3.4.0",
    "typescript": "~5.6.0"
  },
  "engines": {
    "node": ">=20.9.0"
  }
}
